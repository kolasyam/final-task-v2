# Sales Intelligence - Environment Configuration
# Copy this file to .env and adjust values for your environment

# --- Dataset ---
DATASET_PATH=C:\Users\syamm\OneDrive\Desktop\final_standardized_sales_dataset.xlsx

# --- Ollama Configuration ---
OLLAMA_BASE_URL=http://localhost:11434
MODEL_NAME=gemma:2b
FINETUNED_MODEL_NAME=gemma-sales-intel
OLLAMA_TIMEOUT=120

# --- FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000

# --- Streamlit ---
STREAMLIT_PORT=8501

# --- MLflow ---
MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT_NAME=sales-intelligence

# --- Model Artifacts ---
MODEL_DIR=training/saved_model
VECTORIZER_PATH=training/saved_model/vectorizer.joblib
CLASSIFIER_PATH=training/saved_model/classifier.joblib
LABEL_ENCODER_PATH=training/saved_model/label_encoder.joblib

# --- Training ---
TEST_SIZE=0.2
RANDOM_SEED=42
N_ESTIMATORS=200
MAX_FEATURES=5000

# --- Logging ---
LOG_LEVEL=INFO
